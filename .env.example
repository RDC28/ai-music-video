# Supabase Keys
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Google AI (Gemini / Veo)
GOOGLE_AI_API_KEY=your_google_ai_studio_key
GOOGLE_CLOUD_PROJECT_ID=your_gcp_project_id

# Shotstack sandbox editor/export
SHOTSTACK_API_KEY=your_shotstack_sandbox_key
SHOTSTACK_ENV=stage

# Stripe Billing
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_pub_key

# App Settings
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ByteDance / Seedance / Seedream
# Set one of these API keys if you select Seedance video models.
BYTEDANCE_API_KEY=
# SEEDANCE_API_KEY=
# ARK_API_KEY=
BYTEDANCE_BASE_URL=https://ark.ap-southeast.bytepluses.com/api/v3
SEEDANCE_VIDEO_BASE_URL=https://seedanceapi.org/v2
